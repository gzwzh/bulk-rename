        "help": {
            "regex": {
                "title": "Regex Module",
                "content": "【Function Introduction】\nUse regular expressions for advanced filename matching and replacement.\n\n【Basic Operations】\n• Match: Enter regex pattern\n• Replace: Enter replacement text, can use $1, $2 etc. to reference groups\n• Include Extension: Check to include file extension in regex match\n\n【Example】\nMatch: (\\d+)  Replace: 第$1集  → Replace numbers with '第X集'"
            },
            "replace": {
                "title": "Replace Module",
                "content": "【Function Introduction】\nSimple text search and replace functionality.\n\n【Basic Operations】\n• Search: Enter text to find\n• Replace With: Enter replacement text (leave blank to delete)\n• Case Sensitive: Check to strictly match case\n\n【Example】\nSearch: 副本  Replace With: (empty)  → Delete '副本' from filenames"
            },
            "remove": {
                "title": "Remove Module",
                "content": "【Function Introduction】\nRemove specified content from filenames.\n\n【Basic Operations】\n• First/Last: Remove N characters from the beginning/end\n• From/To: Remove characters within a specified range\n• Character/Word: Remove specified character/word\n• Trim: Cut filename based on specified text\n• Checkbox: Remove digits, Chinese characters, symbols etc.\n\n【Example】\nFirst: 3  → Remove first 3 characters of the filename"
            },
            "add": {
                "title": "Add Module",
                "content": "【Function Introduction】\nAdd prefixes, suffixes, or insert text into filenames.\n\n【Basic Operations】\n• Prefix: Add text to the beginning of the filename\n• Suffix: Add text to the end of the filename\n• Insert: Insert text at a specified position\n• Position: Specify insertion position (from 0)\n\n【Example】\nPrefix: [2024]  → Add '[2024]' before all filenames"
            },
            "auto_date": {
                "title": "Auto Date Module",
                "content": "【Function Introduction】\nAutomatically add date and time information to files.\n\n【Basic Operations】\n• Method: Select date addition location (prefix/suffix/fixed)\n• Type: Select date source (creation/modification/access time)\n• Format: Select date format (year-month-day/day-month-year etc.)\n• Separator/Connector: Set date separator and connector\n• Custom: Customize strftime format, e.g. %Y-%m-%d\n\n【Example】\nMethod: Prefix  Format: Year-Month-Day  → 20241208_文件名\nCustom: %Y年%m月%d日  → 2024年12月08日_文件名"
            },
            "number": {
                "title": "Number Module",
                "content": "【Function Introduction】\nAdd sequential numbering to files.\n\n【Basic Operations】\n• Method: Select number position (prefix/suffix/insert)\n• Start/Increment: Set starting value and increment step\n• Alignment: Set digit count (pad with zeros)\n• Type: Decimal/Hexadecimal/Letter\n• Roman Numerals: Use Roman numerals for numbering\n\n【Example】\nMethod: Prefix  Start: 1  Alignment: 3  → 001_文件名"
            },
            "file": {
                "title": "File Name Module",
                "content": "【Function Introduction】\nSet basic processing mode for file names.\n\n【Basic Operations】\n• Keep: Maintain original file name unchanged\n• Remove: Clear file name (requires other modules)\n• Fixed: Replace all file names with specified name\n• Reverse: Reverse order of characters in file name\n\n【Example】\nMode: Fixed  Name: 图片  → All files renamed to '图片'"
            },
            "case": {
                "title": "Case Module",
                "content": "【Function Introduction】\nConvert file name case formats.\n\n【Basic Operations】\n• Uppercase: Convert all to uppercase letters\n• Lowercase: Convert all to lowercase letters\n• Capitalize First Letter: Capitalize first letter of each word\n• Sentence Case: Only capitalize first letter\n• Toggle Case: Swap upper and lower case\n\n【Example】\nMode: Capitalize First Letter  → hello world → Hello World"
            },
            "move_copy": {
                "title": "Move/Copy Module",
                "content": "【Function Introduction】\nMove or copy part of file names.\n\n【Basic Operations】\n• Operation: Choose to copy/move to beginning or end\n• From Position: Starting extraction position (from 0)\n• Character Count: Number of characters to extract\n• Separator: Add between moved/copied content\n\n【Example】\nCopy Start  From: 0  Character Count: 3  → abc_abcdef"
            },
            "folder": {
                "title": "Folder Name Module",
                "content": "【Function Introduction】\nAdd parent folder name to file names.\n\n【Basic Operations】\n• Position: Select to add before or after\n• Separator: Separator between folder name and file name\n• Level: Number of levels up to get folder name\n\n【Example】\nPosition: Prefix  Level: 1  → FolderName_文件名"
            },
            "extension": {
                "title": "Extension Module",
                "content": "【Function Introduction】\nHandle file extensions.\n\n【Basic Operations】\n• Same: Keep extension unchanged\n• Lowercase/Uppercase: Convert extension case\n• Title: Capitalize first letter of extension\n• Fixed: Replace with specified extension\n• Extra: Append to original extension\n• Remove: Delete extension\n\n【Example】\nMode: Lowercase  → .TXT → .txt"
            },
            "selection": {
                "title": "Selection Filter Module",
                "content": "【Function Introduction】\nFilter and select files based on conditions.\n\n【Basic Operations】\n• Filter: Input file name filter condition (supports wildcards)\n• Case Sensitive: Check to strictly match case\n• Folders/Files: Select type to display\n• Hidden: Whether to show hidden files\n• Name Length: Filter by file name length\n• Path Length: Filter by full path length\n\n【Example】\nFilter: *.jpg  → Show only jpg files"
            },
            "new_location": {
                "title": "New Location Module",
                "content": "【Function Introduction】\nMove or copy renamed files to a new location.\n\n【Basic Operations】\n• Path: Select target folder path\n• Copy Not Move: Check to copy file instead of moving\n\n【Notes】\n• If target path does not exist, it will be automatically created\n• Moving operation deletes file from original location\n• Copying operation retains original file\n\n【Example】\nPath: D:\\整理  → Files renamed and moved to D:\\整理"
            }
        },
