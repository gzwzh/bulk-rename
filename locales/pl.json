        "help": {
            "regex": {
                "title": "Moduł wyrażeń regularnych",
                "content": "【Opis funkcji】\nUżywaj wyrażeń regularnych do zaawansowanego dopasowania i zastępowania nazw plików.\n\n【Podstawowe operacje】\n• Dopasowanie: wprowadź wzór wyrażenia regularnego\n• Zastąpienie: wprowadź tekst do zastąpienia, można używać $1, $2 itp. do odwoływania się do grup\n• Zawiera rozszerzenie: zaznacz, aby dopasowanie zawierało rozszerzenie pliku\n\n【Przykład】\nDopasowanie: (\\d+)  Zastąpienie: Tytuł$1  → Zamień liczby na 'TytułX'"
            },
            "replace": {
                "title": "Moduł zastępowania",
                "content": "【Opis funkcji】\nProsta funkcja wyszukiwania i zastępowania tekstu.\n\n【Podstawowe operacje】\n• Szukaj: wprowadź tekst do znalezienia\n• Zastąpić na: wprowadź tekst do zastąpienia (pozostaw puste, aby usunąć)\n• Rozróżniać wielkość liter: zaznacz, aby dokładnie dopasować wielkość liter\n\n【Przykład】\nSzukaj: kopie  Zastąpić na: (puste)  → Usuń 'kopie' z nazwy pliku"
            },
            "remove": {
                "title": "Moduł usuwania",
                "content": "【Opis funkcji】\nUsuwa określone zawartości z nazw plików.\n\n【Podstawowe operacje】\n• Pierwsze/Ostatnie: usuwa N pierwszych lub ostatnich znaków\n• Od/do: usuwa znaki w określonym zakresie pozycji\n• Znak/Słowo: usuwa określony znak lub słowo\n• Wytnij: usuwa według określonego tekstu\n• Checkboxy: usuwa cyfry, znaki Chiniany, znaki specjalne itp.\n\n【Przykład】\nPierwsze: 3  → Usuwa 3 pierwsze znaki z nazwy pliku"
            },
            "add": {
                "title": "Moduł dodawania",
                "content": "【Opis funkcji】\nDodaje prefiks, sufiks lub wstawia tekst do nazw plików.\n\n【Podstawowe operacje】\n• Prefiks: dodaje tekst na początku nazwy pliku\n• Sufiks: dodaje tekst na końcu nazwy pliku\n• Wstaw: wstawia tekst w określonej pozycji\n• Pozycja: określa pozycję wstawienia (od 0)\n\n【Przykład】\nPrefiks: [2024]  → Dodaje '[2024]' przed wszystkimi nazwami plików"
            },
            "auto_date": {
                "title": "Moduł automatycznej daty",
                "content": "【Opis funkcji】\nAutomatycznie dodaje informacje o dacie i czasie do nazw plików.\n\n【Podstawowe operacje】\n• Metoda: wybierz pozycję dodawania daty (prefiks/sufiks/fixed)\n• Typ: wybierz źródło daty (utworzenia/modyfikacji/dostępu)\n• Format: wybierz format daty (rok-miesiąc-dzień/dzień-miesiąc-rok itp.)\n• Oddzielacz/Połącznik: ustaw oddzielnik i połącznik daty\n• Dostosuj: dostosuj format strftime, np. %Y-%m-%d\n\n【Przykład】\nMetoda: prefiks  Format: rok-miesiąc-dzień  → 20241208_nazwa_pliku\nDostosuj: %Y roku %m miesiąca %d dnia  → 2024 roku 12 miesiąca 08 dnia_nazwa_pliku"
            },
            "number": {
                "title": "Moduł numeracyjny",
                "content": "【Opis funkcji】\nDodaje numery do nazw plików.\n\n【Podstawowe operacje】\n• Metoda: Wybierz pozycję numerowania (prefiks/sufiks/wstawienie)\n• Rozpoczęcie/zwiększenie: Ustaw wartość początkową i krok zwiększania\n• Wyrównanie: Ustaw liczbę cyfr (dopelnianie zerami)\n• Typ: dziesiętny/hexadecymalny/literowy\n• Rzymskie liczby: Używa numeracji rzymskiej\n\n【Przykład】\nMetoda: prefiks  Rozpoczęcie: 1  Wyrównanie: 3  → 001_nazwa_pliku"
            },
            "file": {
                "title": "Moduł nazwy pliku",
                "content": "【Opis funkcji】\nUstawia podstawowy sposób przetwarzania nazw plików.\n\n【Podstawowe operacje】\n• Zachowaj: Zachowuje oryginalną nazwę pliku\n• Usuń: Czyści nazwę pliku (wymaga użycia innych modułów)\n• Stale: Zamienia wszystkie nazwy plików na określone nazwy\n• Odwróć: Odwraca kolejność znaków w nazwie pliku\n\n【Przykład】\nTryb: stale  Nazwa: obraz  → Wszystkie pliki zostaną nazwane 'obraz'"
            },
            "case": {
                "title": "Moduł wielkości liter",
                "content": "【Opis funkcji】\nKonwertuje format wielkości liter w nazwach plików.\n\n【Podstawowe operacje】\n• Duże litery: Konwertuje wszystkie litery na duże\n• Małe litery: Konwertuje wszystkie litery na małe\n• Pierwsza litera duża: Pierwsza litera każdego słowa jest duża\n• Pierwsza litera zdania duża: Tylko pierwsza litera jest duża\n• Odwróć: Zamienia wielokrotność wielkich i małych liter\n\n【Przykład】\nTryb: pierwsza litera duża  → hello world → Hello World"
            },
            "move_copy": {
                "title": "Moduł przenoszenia/kopiowania",
                "content": "【Opis funkcji】\nPrzenosi lub kopiuje części nazw plików.\n\n【Podstawowe operacje】\n• Operacja: Wybierz kopiowanie/przenoszenie na początku lub końcu\n• Pozycja początkowa: Początek wyjmowania (od 0)\n• Liczba znaków: Liczba znaków do wyjmowania\n• Separator: Dodawany między kopiowanymi/przeniesionymi zawartościami\n\n【Przykład】\nKopiuj początek  Pozycja: 0  Liczba znaków: 3  → abc_abcdef"
            },
            "folder": {
                "title": "Moduł nazwy folderu",
                "content": "【Opis funkcji】\nDodaje nazwę nadrzędnego folderu do nazwy pliku.\n\n【Podstawowe operacje】\n• Pozycja: Wybierz dodanie przedrostka lub sufiksu\n• Separator: Separator między nazwą folderu a nazwą pliku\n• Poziomów: Ile poziomów folderów powinno być użyte\n\n【Przykład】\nPozycja: przedrostek  Poziom: 1  → nazwa_folderu_nazwa_pliku"
            },
            "extension": {
                "title": "Moduł rozszerzenia",
                "content": "【Opis funkcji】\nObsługuje rozszerzenia plików.\n\n【Podstawowe operacje】\n• Takie jak wcześniej: Zachowuje rozszerzenie bez zmiany\n• Małe/duże litery: Konwertuje rozszerzenie na małe lub duże litery\n• Tytuł: Pierwsza litera rozszerzenia jest duża\n• Stale: Zastępuje rozszerzenie określonym rozszerzeniem\n• Dodatkowe: Dodaje rozszerzenie za oryginałem\n• Usuń: Usuwa rozszerzenie\n\n【Przykład】\nTryb: małe  → .TXT → .txt"
            },
            "selection": {
                "title": "Moduł selekcji/filtrowania",
                "content": "【Opis funkcji】\nFiltruje i wybiera pliki według warunków.\n\n【Podstawowe operacje】\n• Filtrowanie: Wprowadź warunek filtra dla nazw plików (obsługiwane są symboli jokerów)\n• Distingwowanie wielkości liter: Jeśli zaznaczone, wymusza dokładne dopasowanie wielkości liter\n• Folder/Plik: Wybierz typ wyświetlanych elementów\n• Ukryte: Pokaż ukryte pliki?\n• Długość nazwy: Filtruj według długości nazwy pliku\n• Długość ścieżki: Filtruj według całkowitej długości ścieżki\n\n【Przykład】\nFiltrowanie: *.jpg  → Pokaż tylko pliki jpg"
            },
            "new_location": {
                "title": "Moduł nowej lokalizacji",
                "content": "【Opis funkcji】\nPrzenosi lub kopiuje przesłaniane pliki do nowej lokalizacji.\n\n【Podstawowe operacje】\n• Ścieżka: Wybierz celowy folder\n• Kopiowanie bez przenoszenia: Jeśli zaznaczone, kopiuje pliki zamiast przenosić\n\n【Wskazówki】\n• Jeśli cel nie istnieje, zostanie automatycznie utworzony\n• Operacja przenoszenia usuwa plik z oryginalnej lokalizacji\n• Operacja kopiowania zachowuje oryginalny plik\n\n【Przykład】\nŚcieżka: D:\\sortowanie  → Przesłaniany plik zostanie przeniesiony do D:\\sortowanie"
            }
        },
