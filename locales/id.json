        "help": {
            "regex": {
                "title": "Modul Ekspresi Reguler",
                "content": "【Penjelasan Fitur】\nMenggunakan ekspresi reguler untuk pencocokan dan penggantian nama file tingkat lanjut.\n\n【Penggunaan Dasar】\n• Cocokkan: Masukkan pola ekspresi reguler\n• Ganti: Masukkan teks penggantian, dapat menggunakan $1, $2 dll untuk merujuk ke grup\n• Termasuk Ekstensi: Centang jika pencocokan akan mencakup ekstensi file\n\n【Contoh】\nPencocokan: (\\d+)  Penggantian: Episode$1  → Mengubah angka menjadi 'EpisodeX'"
            },
            "replace": {
                "title": "Modul Penggantian",
                "content": "【Penjelasan Fitur】\nFitur pencarian dan penggantian teks sederhana.\n\n【Penggunaan Dasar】\n• Cari: Masukkan teks yang ingin dicari\n• Ganti Menjadi: Masukkan teks penggantian (kosongkan untuk menghapus)\n• Distinggukan Uppercase/Lowercase: Centang jika harus cocok dengan case sensitif\n\n【Contoh】\nCari: Copy  Ganti Menjadi: (kosong)  → Menghapus 'Copy' dari nama file"
            },
            "remove": {
                "title": "Modul Hapus",
                "content": "【Penjelasan Fitur】\nMenghapus konten tertentu dari nama file.\n\n【Penggunaan Dasar】\n• Awal/Akhir: Menghapus N karakter di awal atau akhir\n• Dari/Sampai: Menghapus karakter dalam rentang posisi tertentu\n• Karakter/Kata: Menghapus karakter atau kata tertentu\n• Potongan: Memotong nama file berdasarkan teks tertentu\n• Checkbox: Menghapus angka, huruf Cina, simbol dll\n\n【Contoh】\nAwal: 3  → Menghapus 3 karakter pertama dari nama file"
            },
            "add": {
                "title": "Modul Tambah",
                "content": "【Penjelasan Fitur】\nMenambahkan prafiks, sufiks, atau teks tertentu ke dalam nama file.\n\n【Penggunaan Dasar】\n• Prafiks: Menambahkan teks di awal nama file\n• Sufiks: Menambahkan teks di akhir nama file\n• Tambahkan: Menyisipkan teks di posisi tertentu\n• Posisi: Tentukan posisi penyisipan (mulai dari 0)\n\n【Contoh】\nPrafiks: [2024]  → Menambahkan '[2024]' di depan semua nama file"
            },
            "auto_date": {
                "title": "Modul Tanggal Otomatis",
                "content": "【Penjelasan Fitur】\nMenambahkan informasi tanggal waktu otomatis ke dalam nama file.\n\n【Penggunaan Dasar】\n• Cara: Pilih lokasi penambahan tanggal (prafiks/sufiks/fixed)\n• Jenis: Pilih sumber tanggal (waktu pembuatan/waktu modifikasi/waktu akses)\n• Format: Pilih format tanggal ( tahun-bulan-hari / hari-bulan-tahun dll )\n• Pembatas/Pemisah: Tentukan pembatas dan pemisah tanggal\n• Kustom: Tentukan format strftime khusus, seperti %Y-%m-%d\n\n【Contoh】\nCara: Prafiks  Format: Tahun-Bulan-Hari  → 2024-12-08_NamaFile\nKustom: %Y Tahun %m Bulan %d Hari  → 2024 Tahun 12 Bulan 08 Hari_NamaFile"
            },
            "number": {
                "title": "Modul Nomor",
                "content": "【Penjelasan Fitur】\nMenambahkan nomor urut ke file.\n\n【Penggunaan Dasar】\n• Cara: Pilih posisi penambahan (awalan/akhiran/sisip)\n• Mulai/Ditambahkan: Tentukan nilai awal dan langkah penambahan\n• Ratakan: Tentukan jumlah digit (penuhi dengan nol)\n• Jenis: Desimal/Hexadesimal/Letter\n• Romawi: Gunakan penomoran Romawi\n\n【Contoh】\nCara: Awalan  Mulai: 1  Ratakan: 3  → 001_NamaFile"
            },
            "file": {
                "title": "Modul Nama File",
                "content": "【Penjelasan Fitur】\nMengatur pola dasar pemrosesan nama file.\n\n【Penggunaan Dasar】\n• Tidak berubah: Biarkan nama file tetap sama\n• Hapus: Kosongkan nama file (perlu digabungkan dengan modul lain)\n• Tetapkan: Ganti semua nama file menjadi nama yang ditentukan\n• Balik: Balik urutan karakter dalam nama file\n\n【Contoh】\nPola: Tetapkan  Nama: Gambar  → Semua file diubah menjadi 'Gambar'"
            },
            "case": {
                "title": "Modul Huruf Besar Kecil",
                "content": "【Penjelasan Fitur】\nMengubah format huruf besar kecil dalam nama file.\n\n【Penggunaan Dasar】\n• Kapital: Ubah semua huruf menjadi huruf besar\n• Kecil: Ubah semua huruf menjadi huruf kecil\n• Kapital Awal Kata: Setiap huruf awal kata menjadi huruf besar\n• Kapital Awal Kalimat: Hanya huruf awal kalimat menjadi huruf besar\n• Balik: Menukar huruf besar dan kecil\n\n【Contoh】\nPola: Kapital Awal Kata  → hello world → Hello World"
            },
            "move_copy": {
                "title": "Modul Pindahkan/Copy",
                "content": "【Penjelasan Fitur】\nPindahkan atau salin bagian dari nama file.\n\n【Penggunaan Dasar】\n• Operasi: Pilih untuk menyalin/menempelkan ke awal atau akhir\n• Dari Posisi: Tempat dimulai ekstraksi (dari indeks 0)\n• Jumlah Karakter: Jumlah karakter yang akan diekstrak\n• Penyebab: Menambahkan antara konten yang disalin/menempelkan\n\n【Contoh】\nSalin Awal  Dari: 0  Jumlah Karakter: 3  → abc_abcdef"
            },
            "folder": {
                "title": "Modul Nama Folder",
                "content": "【Penjelasan Fitur】\nMenambahkan nama folder induk ke nama file.\n\n【Penggunaan Dasar】\n• Lokasi: Pilih untuk menambahkan ke awalan atau akhir\n• Penyebab: Penyebab antara nama folder dan nama file\n• Tingkat: Ambil sejumlah tingkat folder atas\n\n【Contoh】\nLokasi: Awalan  Tingkat: 1  → NamaFolder_NamaFile"
            },
            "extension": {
                "title": "Modul Ekstensi",
                "content": "【Penjelasan Fitur】\nMengolah ekstensi file.\n\n【Penggunaan Dasar】\n• Sama: Biarkan ekstensi tidak berubah\n• Kecil/Kapital: Ubah ukuran huruf ekstensi\n• Judul: Kapital huruf pertama ekstensi\n• Tetapkan: Ganti dengan ekstensi yang ditentukan\n• Tambahan: Tambahkan di belakang ekstensi asli\n• Hapus: Hapus ekstensi\n\n【Contoh】\nPola: Kecil  → .TXT → .txt"
            },
            "selection": {
                "title": "Modul Pemilihan Filter",
                "content": "【Penjelasan Fitur】\nFilter dan pilih file berdasarkan kondisi.\n\n【Penggunaan Dasar】\n• Filter: Masukkan kondisi filter nama file (mendukung wildcard)\n• Distinggu Huruf Besar: Centang untuk membatasi pencocokan huruf besar\n• Folder/File: Pilih jenis tampilan\n•sembunyi: Apakah tampilkan file tersembunyi\n• Panjang Nama: Filter berdasarkan panjang nama file\n• Panjang Path: Filter berdasarkan panjang path lengkap\n\n【Contoh】\nFilter: *.jpg  → Hanya menampilkan file jpg"
            },
            "new_location": {
                "title": "Modul Lokasi Baru",
                "content": "【Penjelasan Fitur】\nPindahkan atau salin file yang telah direname ke lokasi baru.\n\n【Penggunaan Dasar】\n• Jalur: Pilih jalur folder tujuan\n• Salin Tidak Pindahkan: Centang untuk menyalin file bukan memindahkan\n\n【Perhatian】\n• Jika jalur tujuan tidak ada akan secara otomatis dibuat\n• Operasi pindahkan akan menghapus file dari posisi aslinya\n• Operasi salin akan mempertahankan file asli\n\n【Contoh】\nJalur: D:\\Organisir  → File setelah direname dipindahkan ke D:\\Organisir"
            }
        },
